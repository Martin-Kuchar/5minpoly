# Required for production (real trades) and redemption
PRIVATE_KEY=0x

# Polymarket proxy/profile wallet (if using proxy)
# When using an EOA private key, you can leave this field blank
PROXY_WALLET_ADDRESS=

# 0=EOA, 1=Proxy
SIGNATURE_TYPE=0

# Polling
CHECK_INTERVAL_MS=1000
MARKET_CLOSURE_CHECK_INTERVAL_SECONDS=20

# Markets: btc, eth, sol, xrp (comma-separated, lowercase recommended)
MARKETS=btc

# Dump-and-hedge strategy
DUMP_HEDGE_SHARES=10
DUMP_HEDGE_SUM_TARGET=0.95
DUMP_HEDGE_MOVE_THRESHOLD=0.15
DUMP_HEDGE_WINDOW_MINUTES=2
DUMP_HEDGE_STOP_LOSS_MAX_WAIT_MINUTES=5
# Used as a cap on forced hedge sum: max(leg1 + opposite leg) = 1 + percentage
DUMP_HEDGE_STOP_LOSS_PERCENTAGE=0.2
# Buy offsets (seconds before market close), comma-separated
DUMP_HEDGE_BUY_OFFSETS_SECONDS=120,60,30,20,10

# false=simulation (default), true=real trades
PRODUCTION=false
